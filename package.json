{
  "name": "tel-bot",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "predev": "node scripts/check-node-version.cjs",
    "dev": "NODE_OPTIONS=--dns-result-order=ipv4first tsx watch src/index.ts",
    "prestart": "node scripts/check-node-version.cjs",
    "build": "tsc",
    "start": "NODE_OPTIONS=--dns-result-order=ipv4first node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^6.16.2",
    "@prisma/client": "^6.16.2",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^18.19.122",
    "prisma": "^6.16.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
